# FlahaSOIL v2 API — environment variables
#
# IMPORTANT: This file is for the v2 backend ONLY. The legacy backend in
# api-implementation/ uses a separate .env with DATABASE_URL pointing at
# the SQLite dev.db. Do not point both stacks at the same database.
#
# Copy this file to backend/.env and fill in real credentials. Never
# commit a real .env to git.

# Prisma v2 datasource (PostgreSQL). Must be a real reachable URL when
# running migrations or hitting the database from running code; can be
# left as a placeholder for `prisma generate` and for unit tests that
# do not touch the database layer.
DATABASE_URL_V2="postgresql://USER:PASSWORD@localhost:5432/flahasoil_v2?schema=public"

# HTTP server
PORT=3002
NODE_ENV=development
