# FlahaSOIL v2 API — environment variables
#
# IMPORTANT: This file is for the v2 backend ONLY. The legacy backend in
# api-implementation/ uses a separate .env with DATABASE_URL pointing at
# the SQLite dev.db. Do not point both stacks at the same database.
#
# Copy this file to backend/.env and fill in real credentials. Never
# commit a real .env to git.

# Prisma v2 datasource (PostgreSQL). Must be a real reachable URL when
# running migrations or hitting the database from running code; can be
# left as a placeholder for `prisma generate` and for unit tests that
# do not touch the database layer.
DATABASE_URL_V2="postgresql://USER:PASSWORD@localhost:5432/flahasoil_v2?schema=public"

# HTTP server
PORT=3002
NODE_ENV=development

# Comma-separated allowlist of SPA origins that may call the API. Required
# in production because the refresh-token cookie is HttpOnly and the SPA
# fetches use `credentials: include`, which forbids a wildcard origin.
# Default (dev): http://localhost:5173 (Vite dev server).
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Phase 9A-C — Authentication
# -----------------------------------------------------------------------------
# JWT_SECRET signs access tokens (HS256). REQUIRED in production; at
# least 32 characters. In development/test a deterministic per-machine
# fallback is derived if unset, so issued tokens survive `tsx watch`
# reloads. Generate with: openssl rand -hex 32
JWT_SECRET=

# Access-token lifetime in minutes (default 15). Refresh-token lifetime
# in days (default 30). Both are positive integers.
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Refresh-token cookie attributes. Defaults are dev-friendly: insecure
# cookie name `fsoil_rt`, no Domain attribute, Secure=false (so the
# cookie is set over http://localhost), SameSite=lax. Set
# AUTH_COOKIE_SECURE=true and SameSite=none if you serve the API and
# the SPA from different origins over HTTPS.
AUTH_REFRESH_COOKIE_NAME=fsoil_rt
# AUTH_COOKIE_DOMAIN=.flahasoil.com
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# Phase 9A-E — Dev auth fallback
# -----------------------------------------------------------------------------
# When true, /api/v2/* requests without a JWT bearer token fall back to
# the x-dev-user-id resolver (or the seeded dev user). Intended for
# local development only.
#
# Default in every environment: FALSE. Tests that need the dev resolver
# must set ALLOW_DEV_AUTH=true explicitly. The boot path refuses to
# start when this is true under NODE_ENV=production — a misconfigured
# deploy must fail loudly, not silently downgrade.
ALLOW_DEV_AUTH=true
