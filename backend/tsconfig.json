{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"target": "ES2022",
		"types": ["node"],
		"jsx": "preserve",
		"noEmit": false,
		"declaration": false,
		"declarationMap": false,
		"exactOptionalPropertyTypes": false
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules", "src/**/__tests__/**"]
}
