# FlahaSOIL v2 frontend — environment variables
#
# Vite only exposes variables prefixed with VITE_ to client code. Copy
# this file to frontend/.env (or frontend/.env.local) and adjust as
# needed. Never commit a real .env to git.

# Base URL of the v2 backend, including the /api/v2 prefix. Used by the
# real fetch-based API client.
VITE_API_BASE_URL="http://localhost:3002/api/v2"

# When "true", the frontend uses the in-memory mockApiV2Client and never
# performs a network call. Any other value (or unset) uses
# realApiV2Client against VITE_API_BASE_URL.
#
# Phase 9A-G flipped the default to "real" so the production path is the
# safe default and a stray missing env var never silently runs the SPA
# against fixtures. Opt into mock mode only when iterating on UI without
# a running backend.
VITE_USE_MOCK_API="false"
