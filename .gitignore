# Ignore node_modules if using npm tooling
node_modules/
.DS_Store
*.log

# Local env files — never commit secrets. Templates live in *.env.example.
.env
.env.local
.env.*.local
backend/.env
backend/.env.local
frontend/.env
frontend/.env.local

# Prisma generated client (regenerated locally, not source-controlled)
prisma/generated/

# Build artifacts (regenerated by tsc/vite, not source-controlled)
dist/
*.tsbuildinfo

# Dev launcher runtime artefacts (PID files written by scripts/dev-v2.ps1)
logs/*.pid